PORT=3002
# Comma-separated regex patterns (omit to use built-in defaults for localhost + Vercel):
# CORS_ORIGIN=^http://localhost(:\d+)?$,^https://live-stream-aggregator\.vercel\.app$,^https://live-stream-aggregator-[a-z0-9-]+-tejasvimehras-projects\.vercel\.app$
PUBLIC_API_BASE=http://localhost:3002
# Production example:
# PUBLIC_API_BASE=https://live-stream-aggregator-backend-production.up.railway.app

# Comma-separated hostnames allowed through the HLS proxy (empty = allow all public hosts)
# Production catalog hostnames (+ Red Bull segment CDN cs.liiift.io from rewritten playlists):
PROXY_ALLOWLIST=cs.liiift.io,devstreaming-cdn.apple.com,edge13.vedge.infomaniak.com,kanal75xto-llhls.akamaized.net,na.linear.zype.com,play.redbull.com,rthktv35-vos-live.akamaized.net,streams2.sofast.tv,streamtv.as3sport.online

# YouTube live detection (playback always uses iframe embed in the web app)
# YOUTUBE_DATA_API_KEY=
# YOUTUBE_LIVE_METHOD=auto
# YOUTUBE_LIVE_METHOD=scrape
# YOUTUBE_LIVE_METHOD=data_api

# Web app repo: https://github.com/tejasvi-mehra/live-stream-aggregator
# Live API: https://live-stream-aggregator-backend-production.up.railway.app/
